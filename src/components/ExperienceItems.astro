---
interface Props {
  title: string;
  description: string;
  company: string;
  dateIn: string;
  dateOut: string;
}

const { title, description, company, dateIn, dateOut } = Astro.props;
---

<div class="hover-3d">
  <div class="card bg-neutral shadow-xl rounded-xl w-96 p-5 shadow-lg">
    <div class="card-body">
      <span class="badge badge-outline badge-primary badge-lg"
        >{dateIn} - {dateOut}</span
      >
      <h2 class="card-title font-bold text-2xl">{title}</h2>
      <p class="opacity-60 text-lg">{description}</p>
      <div class="card-actions justify-end">
        <span class="badge   badge-primary badge-lg">{company}</span>
      </div>
    </div>
  </div>
  <div></div>
  <div></div>
  <div></div>
  <div></div>
  <div></div>
  <div></div>
  <div></div>
  <div></div>
</div>
